{
  "theme": "Light",
  "archetype": "1 (Organic & Earthy) blended with vibrant Indian marketplace context",
  "design_philosophy": "LocalVibe balances the warmth and trust of an organic palette with vibrant, energetic accents representing the rich Indian cultural context (weddings, food, celebrations). The interface uses generous spacing, soft geometry, and high-quality creator imagery to inspire confidence.",
  "colors": {
    "primary": "#E11D48",
    "primary_hover": "#BE123C",
    "primary_muted": "#FFE4E6",
    "background": "#FAFAF9",
    "surface": "#FFFFFF",
    "text_primary": "#1C1917",
    "text_secondary": "#57534E",
    "border": "#E7E5E4",
    "success": "#16A34A",
    "success_muted": "#DCFCE7",
    "warning": "#F59E0B",
    "overlay": "rgba(0,0,0,0.4)"
  },
  "typography": {
    "heading_font": "Outfit",
    "body_font": "Manrope",
    "scale": {
      "h1": "text-3xl md:text-4xl font-bold tracking-tight text-stone-900",
      "h2": "text-2xl font-bold tracking-tight text-stone-900",
      "h3": "text-xl font-semibold text-stone-900",
      "body": "text-base leading-relaxed text-stone-600",
      "small": "text-sm text-stone-500",
      "caption": "text-xs tracking-wide uppercase font-semibold text-stone-400"
    }
  },
  "spacing": {
    "screen_padding": "p-4 md:p-6",
    "card_padding": "p-4",
    "gap_small": "gap-2",
    "gap_medium": "gap-4",
    "gap_large": "gap-6",
    "section_margin": "mb-8"
  },
  "border_radius": {
    "card": "rounded-2xl",
    "button": "rounded-xl",
    "chip": "rounded-full",
    "image": "rounded-xl",
    "sheet": "rounded-t-3xl"
  },
  "components": {
    "button": {
      "primary": "bg-rose-600 text-white rounded-xl py-3.5 px-6 font-semibold flex items-center justify-center space-x-2 active:bg-rose-700 transition-colors",
      "outline": "border-2 border-stone-200 text-stone-800 rounded-xl py-3.5 px-6 font-semibold flex items-center justify-center space-x-2 active:border-rose-600 transition-colors",
      "ghost": "text-stone-600 active:bg-stone-100 rounded-xl py-3.5 px-6 font-medium transition-colors"
    },
    "card": {
      "provider_large": "bg-white rounded-2xl shadow-sm border border-stone-100 overflow-hidden flex flex-col active:scale-[0.98] transition-transform",
      "provider_compact": "bg-white rounded-xl shadow-sm border border-stone-100 p-3 flex flex-row items-center gap-3",
      "review": "bg-stone-50 rounded-xl p-4 border border-stone-100"
    },
    "input": "bg-stone-50 border border-stone-200 text-stone-900 rounded-xl px-4 py-3.5 w-full focus:border-rose-600 focus:bg-white transition-all text-base",
    "chip": {
      "default": "px-4 py-2 rounded-full border border-stone-200 text-sm font-medium text-stone-700 bg-white active:bg-stone-50",
      "active": "px-4 py-2 rounded-full border border-rose-600 text-sm font-medium text-rose-700 bg-rose-50"
    },
    "badge": "px-2 py-1 bg-green-50 text-green-700 text-xs font-bold rounded-md flex items-center gap-1 uppercase tracking-wide",
    "bottom_sheet": "bg-white rounded-t-3xl shadow-[0_-8px_30px_rgba(0,0,0,0.1)] p-6 pb-8"
  },
  "screens": {
    "home_discover": {
      "layout": "Vertical scroll with Sticky Header",
      "sections": [
        "Header: App Logo (left) + Location Selector Pill (right, with map-pin icon)",
        "Hero Text: 'Find the best local creators for your event'",
        "Search Bar: Prominent input with search icon, placeholder 'Search bakers, MUAs...'",
        "Categories Grid: 3x2 grid. Each item has a circular icon background (rose-50) and label below",
        "Featured Section: 'Trending in <City>'. Horizontal scroll of large provider cards.",
        "Recent Reviews: Horizontal scroll of compact review cards to build immediate trust"
      ]
    },
    "search_results": {
      "layout": "Vertical list with Sticky Filter Bar",
      "sections": [
        "Header: Back arrow + Search Query ('Makeup Artists in Delhi')",
        "Filter Bar: Horizontal scrollable row of Chips (Sort, Price, Rating, Availability)",
        "List: Vertical list of Provider Cards. Each card shows cover photo, provider avatar, name, category, rating (star icon), starting price, and verified badge."
      ]
    },
    "provider_profile": {
      "layout": "Vertical scroll with Parallax Header & Sticky Bottom CTA",
      "sections": [
        "Cover Image: Aspect 16:9, absolute back button",
        "Profile Info: Avatar overlapping cover, Name, Category, Location, Rating (clickable to reviews), Verified Badge",
        "Action Row: Share, Save/Bookmark icons",
        "Tabs (Sticky): Portfolio | Services | Reviews",
        "Portfolio Tab: Masonry grid of image thumbnails",
        "Services Tab: Vertical list of service items (Title, Description, Price, 'Add' or 'Select' button)",
        "Reviews Tab: Aggregate rating block + List of review cards",
        "Sticky Bottom Bar: WhatsApp Chat (Green) & Request Quote (Primary Rose) buttons"
      ]
    },
    "inquiry_modal": {
      "layout": "Bottom Sheet (Modal)",
      "fields": [
        "Header: 'Request a Quote'",
        "Event Type: Dropdown/Select",
        "Date: Datepicker input",
        "Budget: Number input with currency symbol (₹)",
        "Message: Textarea (4 lines)",
        "Submit: Primary full-width button 'Send Inquiry'"
      ]
    },
    "provider_dashboard": {
      "layout": "Tab Navigation (Home, Portfolio, Leads, Profile)",
      "sections": [
        "Header: 'Welcome back, [Name]'",
        "Stats Row: Active Leads, Profile Views, Average Rating",
        "Recent Leads: List of incoming inquiries with 'Accept'/'Decline' or 'Reply via WhatsApp'",
        "Quick Actions: 'Upload to Portfolio', 'Update Pricing'"
      ]
    }
  },
